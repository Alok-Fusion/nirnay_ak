# =========================================================================
#             NIRNAY App Environment Settings (Template)
# =========================================================================

# Secret key for JWT session tokens
SECRET_KEY=nirnay_super_secret_key_change_me_in_production

# Local SQLite Database url
DATABASE_URL=sqlite:///./nirnay.db

# Groq Cloud API Credentials (Paste your Groq API Key here)
GROQ_API_KEY=

# Preferred LLM model for agents reasoning
GROQ_MODEL=llama3-8b-8192
